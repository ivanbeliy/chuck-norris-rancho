# Discord bot token (Discord Developer Portal -> Bot -> Reset Token)
DISCORD_BOT_TOKEN=

# Path to SQLite database file (relative to relay working directory)
RELAY_DB_PATH=./relay.db

# Default projects directory on Mac Mini
PROJECTS_DIR=/Users/i.beliy/projects

# Task timeout in milliseconds (default: 10 minutes)
RELAY_TASK_TIMEOUT_MS=600000

# Maximum concurrent claude -p processes across all projects (default: 2).
# Values < 1 are clamped to 1 with a warning. Excess spawns wait in a FIFO queue.
RELAY_MAX_CONCURRENT_CLAUDE=2

# How often to sample spawned claude RSS in ms (default: 5000). Set to 0 to disable.
# Peak RSS is recorded in the spawn_log table for diagnosing memory pressure.
RELAY_RSS_SAMPLE_INTERVAL_MS=5000

# Timezone
TZ=Europe/Kyiv
