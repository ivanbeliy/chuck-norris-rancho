# NanoClaw .env — скопіювати як /root/nanoclaw/.env
# Заповнити CLAUDE_CODE_OAUTH_TOKEN (claude setup-token на VM)
# Заповнити DISCORD_BOT_TOKEN (Discord Developer Portal → Bot → Reset Token)

CLAUDE_CODE_OAUTH_TOKEN=
DISCORD_BOT_TOKEN=
ASSISTANT_NAME=WhiteClaw
ASSISTANT_HAS_OWN_NUMBER=true
TZ=Europe/Kyiv
MAX_CONCURRENT_CONTAINERS=2
