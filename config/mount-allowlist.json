{
  "allowedRoots": [
    {
      "path": "/root/shared",
      "allowReadWrite": true,
      "description": "Shared folder with Windows workstation (via Syncthing)"
    },
    {
      "path": "/root/projects",
      "allowReadWrite": true,
      "description": "Development projects on the VM"
    }
  ],
  "blockedPatterns": [
    "password",
    "secret",
    "token",
    ".env"
  ],
  "nonMainReadOnly": true
}
