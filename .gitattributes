# Normalize line endings: LF in repo and in working tree on all platforms.
# Kills CRLF/LF phantom modifies on Windows clients.
* text=auto eol=lf

# Shell scripts and plists are executed on macOS/Linux — LF is mandatory.
*.sh   text eol=lf
*.plist text eol=lf

# Binaries: never convert.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tar  binary
*.woff  binary
*.woff2 binary

# Node native binding artifacts (in node_modules, but be safe).
*.node binary
