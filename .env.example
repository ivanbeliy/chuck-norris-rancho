# === DigitalOcean ===
DO_API_TOKEN=                    # API токен з cloud.digitalocean.com → API
DO_DROPLET_IP=                   # IP дроплету (заповнюється після створення)
DO_SSH_KEY_FINGERPRINT=          # Відбиток SSH-ключа в DigitalOcean

# === Claude Authentication ===
CLAUDE_CODE_OAUTH_TOKEN=         # Токен з `claude setup-token` на VM

# === NanoClaw ===
ASSISTANT_NAME=WhiteClaw
ASSISTANT_HAS_OWN_NUMBER=true
TZ=Europe/Kyiv                   # Часова зона для cron-задач

# === VM Paths ===
NANOCLAW_DIR=/root/nanoclaw
SHARED_DIR=/root/shared
PROJECTS_DIR=/root/projects
